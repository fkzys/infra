<?xml version="1.0" encoding="utf-8"?>
<zone>
  <short>Public</short>
  <description>Managed by infra repo — {{ instance_name }}</description>
  <service name="dhcpv6-client"/>
  <port protocol="tcp" port="{{ instance.ssh_port | default(common.ssh_port) }}"/>
  <protocol value="icmp"/>
  <protocol value="ipv6-icmp"/>
{% if instance.web | default(false) %}
  <service name="http"/>
  <service name="https"/>
  <service name="http3"/>
{% endif %}
{% if instance.turn | default(false) %}
  <service name="stun"/>
  <service name="stuns"/>
  <service name="turn"/>
  <service name="turns"/>
  <port protocol="udp" port="49152-57952"/>
  {% endif %}
{% if instance.mirotalk | default(false) %}
  <port protocol="udp" port="40000-40100"/>
  <port protocol="tcp" port="40000-40100"/>
{% endif %}
{% if instance.jitsi | default(false) %}
  <port protocol="udp" port="{{ instance.jitsi_port | default(common.jitsi_port) }}"/>
{% endif %}
{% if instance.wg_endpoint | default(false) %}
  <port protocol="udp" port="{{ common.wg_port }}"/>
{% endif %}
{% if instance.livekit | default(false) %}
  <port protocol="tcp" port="7881"/>
  <port protocol="udp" port="50100-50200"/>
{% endif %}
{% if instance.i2pd | default(false) %}
  <port protocol="tcp" port="{{ common.i2pd_port }}"/>
  <port protocol="udp" port="{{ common.i2pd_port }}"/>
{% endif %}
  <forward/>
</zone>
