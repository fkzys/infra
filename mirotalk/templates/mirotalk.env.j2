# MiroTalk SFU — minimal env (managed by infra repo)

NODE_ENV=production

TRUST_PROXY=true

# mediasoup WebRTC config
SFU_ANNOUNCED_IP={{ mirotalk.announced_ip }}
SFU_LISTEN_IP=0.0.0.0
SFU_SERVER=true
SFU_NUM_WORKERS=1
SFU_MIN_PORT=40000
SFU_MAX_PORT=40100

SERVER_HOST_URL=https://{{ mirotalk.domain }}

HOST_PROTECTED=true
HOST_USER_AUTH=false
HOST_USERS={{ mirotalk.host_users }}

API_KEY_SECRET={{ mirotalk.api_key_secret }}

JWT_SECRET={{ mirotalk.jwt_secret }}

RECORDING_ENABLED=false
RTMP_ENABLED=false
STATS_ENABLED=false
CHATGPT_ENABLED=false
DEEP_SEEK_ENABLED=false
EMAIL_ALERTS_ENABLED=false
SURVEY_ENABLED=false
WEBHOOK_ENABLED=false
SENTRY_ENABLED=false
