[Unit]
Description={{ basename }} container

[Container]
Image={{ current_instance.image if current_instance.image else common.image }}
ContainerName={{ basename }}
Pod={{ basename }}.pod
Exec=-D /var/lib/{{ basename }} -C /etc/{{ basename }}/ run
AutoUpdate=registry
Volume={{ current_instance.volume_path if current_instance.volume_path else common.volume_path }}/settings:/etc/{{ basename }}:ro
Volume={{ current_instance.volume_path if current_instance.volume_path else common.volume_path }}/cache:/var/lib/{{ basename }}/cache
Volume=/etc/localtime:/etc/localtime:ro
Volume=/etc/ssl/certs/{{ common.domain }}.crt:/etc/ssl/certs/{{ common.domain }}.crt:ro
Volume=/etc/ssl/private/{{ common.domain }}.key:/etc/ssl/private/{{ common.domain }}.key:ro

Label=traefik.enable=true
Label=traefik.tcp.routers.{{ basename }}_naive.entryPoints=https
Label=traefik.tcp.routers.{{ basename }}_naive.rule=HostSNI(`{{ current_instance.reality.server_name }}`)
Label=traefik.tcp.routers.{{ basename }}_naive.service={{ basename }}_naive
Label=traefik.tcp.routers.{{ basename }}_naive.tls=true
Label=traefik.tcp.services.{{ basename }}_naive.loadbalancer.server.port=8443
Label=traefik.tcp.routers.{{ basename }}_naive.tls.passthrough=true

[Service]
Restart=always
[Install]
WantedBy=multi-user.target
