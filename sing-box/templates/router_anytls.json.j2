{# templates/router_anytls.json.j2 #}
{
  "outbounds": [
{% set target = relay_instances if relay_instances else instances %}
{% for name, inst in target.items() %}
    {
      "type": "anytls",
      "tag": "anytls-{{ loop.index }}",
      "server": "{{ inst.address }}",
      "server_port": 443,
      "password": "{{ current_user.password }}",
      "idle_session_timeout": "120s",
      "idle_session_check_interval": "60s",
      "min_idle_session": 2,
      "tls": {
        "enabled": true,
        "server_name": "{{ inst.reality.server_name }}",
        "insecure": false,
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "{{ public_key }}",
          "short_id": "{{ current_user.short_id }}"
        }
      },
      "routing_mark": {{ router.routing_mark }}
    }{{ "," if not loop.last else "" }}
{% endfor %}
  ]
}
